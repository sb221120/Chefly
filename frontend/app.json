{
  "expo": {
    "name": "CHEFLY",
    "slug": "chefly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chefly",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan wine shelves for AI recommendations",
        "NSPhotoLibraryUsageDescription": "Select photos of wine bottles for analysis",
        "NSMicrophoneUsageDescription": "Voice commands for sommelier assistant",
        "NSSpeechRecognitionUsageDescription": "Voice recognition for wine queries"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CHEFLY to access your photos for wine analysis",
          "cameraPermission": "Allow CHEFLY to access your camera to scan wine shelves"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow CHEFLY to use your microphone for voice commands"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
